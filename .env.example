# Copy to `.env` on the box and fill in. `.env` is gitignored — real secrets
# NEVER get committed. The two IMGPROXY_* values must match the co-infra-img
# Worker's `wrangler secret` values exactly. Generate them with scripts/gen-keys.sh.

# Host Traefik routes to imgproxy on.
IMGPROXY_DOMAIN=imgproxy.infra.coop

# imgproxy signed-URL keys (hex). MUST match the Worker secrets.
IMGPROXY_KEY=
IMGPROXY_SALT=

# Jetstream consumer. Purges the CDN cache when an account is deleted.
# PURGE_URL is the Worker's purge endpoint. PURGE_TOKEN must match the Worker's
# PURGE_TOKEN secret.
PURGE_URL=https://img.infra.coop/admin/purge
PURGE_TOKEN=
JETSTREAM_URL=wss://jetstream1.us-east.bsky.network/subscribe
